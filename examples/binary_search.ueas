@Complexity("O(log N)")
algorithm BinarySearch(data: List, target: Integer) -> Integer:

    low = 0
    high = data.length - 1

    while low <= high:
        mid = low + (high - low) / 2
        
        if data[mid] == target:
            return mid
        elif data[mid] < target:
            low = mid + 1
        else:
            high = mid - 1

    return -1
