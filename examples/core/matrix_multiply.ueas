Algorithm MatrixMultiply(A, B)
    Require: A: Matrix, B: Matrix
    Ensure: Matrix
    Complexity: "O(R * C * K)"

    result <- zeroMatrix(R, K)

    for each i in range(0, R) do
        for each j in range(0, K) do
            sum <- 0.0

            for each k in range(0, C) do
                sum <- sum + A[i][k] * B[k][j]
            end for

            result[i][j] <- sum
        end for
    end for

    return result
