Algorithm BinarySearch(data, target)
    Require: data: List, target: Integer
    Ensure: Integer
    Complexity: "O(log N)"

    low <- 0
    high <- data.length - 1

    while low <= high do
        mid <- low + (high - low) / 2

        if data[mid] == target then
            return mid
        else if data[mid] < target then
            low <- mid + 1
        else
            high <- mid - 1
        end if
    end while

    return -1
