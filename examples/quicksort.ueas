Algorithm QuickSort(data)
    Require: data: List
    Ensure: List
    Complexity: "O(N log N)"

    if data.length <= 1 then
        return data
    end if

    pivot <- data[0]
    left <- []
    right <- []

    for each item in data[1:] do
        if item <= pivot then
            left.append(item)
        else
            right.append(item)
        end if
    end for

    return QuickSort(left) + [pivot] + QuickSort(right)
