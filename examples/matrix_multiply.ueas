@Complexity("O(R * C * K)")
algorithm MatrixMultiply(A: Matrix, B: Matrix) -> Matrix:

    result = zeroMatrix(R, K)

    for i in range(0, R):
        for j in range(0, K):
            sum = 0.0

            for k in range(0, C):
                sum = sum + A[i][k] * B[k][j]

            result[i][j] = sum

    return result
