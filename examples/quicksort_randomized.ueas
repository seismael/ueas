Algorithm QuickSortRandomized(data)
    Require: data: List
    Ensure: List
    Complexity: "O(N log N)"
    Memory: "O(N)"

    pivotIndex <- randInt(0, data.length - 1)
    pivot <- data[pivotIndex]
    left <- []
    right <- []

    for each item in data do
        if item < pivot then
            left.append(item)
        else if item > pivot then
            right.append(item)
        end if
    end for

    return QuickSortRandomized(left) + [pivot] + QuickSortRandomized(right)
