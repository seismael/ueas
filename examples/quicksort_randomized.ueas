@Complexity("O(N log N)")
@Memory("O(N)")
algorithm QuickSortRandomized(data: List) -> List:

    pivotIndex = randInt(0, data.length - 1)
    pivot = data[pivotIndex]
    left = []
    right = []

    for item in data:
        if item < pivot:
            left.append(item)
        elif item > pivot:
            right.append(item)

    return QuickSortRandomized(left) + [pivot] + QuickSortRandomized(right)
