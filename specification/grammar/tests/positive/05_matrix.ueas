import MatrixMath

Algorithm MatrixScale(m, scalar)
    Require: m: Matrix<3, 3, Real>, scalar: Real
    Ensure: Matrix<3, 3, Real>
    Complexity: "O(1)"

    result <- zeroMatrix(3, 3)
    i <- 0
    while i < 3 do
        j <- 0
        while j < 3 do
            result[i][j] <- m[i][j] * scalar
            j <- j + 1
        end while
        i <- i + 1
    end while
    return result
