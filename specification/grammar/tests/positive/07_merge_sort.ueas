import ListUtils

Algorithm MergeSort(data)
    Require: data: List<Integer>
    Ensure: List<Integer>
    Complexity: "O(N log N)"

    if length(data) <= 1 then
        return data
    end if

    mid <- length(data) / 2
    left <- slice(data, 0, mid)
    right <- slice(data, mid, length(data))

    return Merge(MergeSort(left), MergeSort(right))
