Algorithm SetOps(a, b)
    Require: a: Set<Integer>, b: Set<Integer>
    Ensure: Set<Integer>
    Complexity: "O(N)", N = cardinality(a) + cardinality(b)

    union <- a.union(b)
    intersection <- a.intersection(b)
    assert(cardinality(intersection) <= cardinality(union), "Intersection must be subset of union")
    return union
