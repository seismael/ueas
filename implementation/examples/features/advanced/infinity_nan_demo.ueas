Algorithm InfinityDemo(data)
    Require: data: List
    Ensure: Real
    Complexity: "O(N)"

    Infinity
    NaN

    minDist <- 999999.0
    i <- 0

    while i < data.length do
        if data[i] < minDist then
            minDist <- data[i]
        end if
        i <- i + 1
    end while

    if minDist == 999999.0 then
        return 0.0
    end if

    return minDist
end Algorithm
