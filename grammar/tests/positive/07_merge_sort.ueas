import ListUtils

algorithm MergeSort(data: List<Integer>) -> List<Integer>
    @Complexity("O(N log N)")
{
    if length(data) <= 1 {
        return data
    }

    let mid: Integer := length(data) / 2
    let left: List<Integer> := slice(data, 0, mid)
    let right: List<Integer> := slice(data, mid, length(data))

    return Merge(MergeSort(left), MergeSort(right))
}
