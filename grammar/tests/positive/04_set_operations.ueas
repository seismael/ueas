algorithm SetOps(a: Set<Integer>, b: Set<Integer>) -> Set<Integer>
    @Complexity("O(N)", N = cardinality(a) + cardinality(b))
{
    let union: Set<Integer> := a.union(b)
    let intersection: Set<Integer> := a.intersection(b)
    assert(cardinality(intersection) <= cardinality(union)): "Intersection must be subset of union"
    return union
}
